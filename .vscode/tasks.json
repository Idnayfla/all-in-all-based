{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto Setup (Node + deps + Claude CLI)",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\setup-claude.ps1"],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    }
  ]
}
