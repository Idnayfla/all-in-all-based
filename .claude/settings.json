{
  "worktree": {
    "bgIsolation": "none"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\Hus Alfyandi\\.vscode\\all-in-all-based\\.claude\\hooks\\save-session.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\Hus Alfyandi\\.vscode\\all-in-all-based\\.claude\\hooks\\save-session.js\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch",
      "WebFetch(*)",
      "Skill(*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete --force *)",
      "Bash(rm -rf *)",
      "Bash(Remove-Item -Recurse -Force *)",
      "Bash(gh pr create*)",
      "Bash(gh pr close*)",
      "Bash(gh issue create*)",
      "Bash(gh release create*)",
      "Bash(drop *)",
      "Bash(DELETE FROM *)"
    ]
  }
}
